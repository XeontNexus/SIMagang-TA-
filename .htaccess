<?php
require_once 'config/config.php';

// Protect admin routes from direct access
if(strpos($_SERVER['REQUEST_URI'], '/admin') !== false) {
    header('HTTP/1.0 403 Forbidden');
    echo '<h1>Access Denied</h1>';
    echo '<p>Direct access to admin routes is not allowed for security reasons.</p>';
    echo '<p>Please use the main login page: <a href="index.php">Login Here</a></p>';
    exit;
}

// Handle login
if($_SERVER['REQUEST_METHOD'] == 'POST') {
    $username = $_POST['username'];
    $password = $_POST['password'];
    
    $db = new Database();
    $db->query('SELECT * FROM users WHERE username = :username');
    $db->bind(':username', $username);
    $user = $db->single();
    
    if($user && password_verify($password, $user['password'])) {
        // Check if student has incomplete profile
        if($user['role'] === 'student') {
            $profileIncomplete = empty($user['institusi']) || empty($user['no_hp']) || empty($user['jurusan_id']) || empty($user['alamat_magang']);
            if($profileIncomplete && !isset($_SESSION['profile_completed'])) {
                $_SESSION['show_profile_modal'] = true;
            }
        }
        
        $_SESSION['user_id'] = $user['id'];
        $_SESSION['username'] = $user['username'];
        $_SESSION['nama_lengkap'] = $user['nama_lengkap'];
        $_SESSION['email'] = $user['email'];
        $_SESSION['role'] = $user['role'];
        
        redirect(base_url('dashboard.php'));
    } else {
        $error = 'Username atau password salah!';
    }
}
?>

